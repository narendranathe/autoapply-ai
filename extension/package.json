{
  "name": "autoapply-ai-extension",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build && node build-content.mjs && node scripts/verify-manifest.mjs",
    "build:dev": "vite build --mode development && node build-content.mjs",
    "build:content": "node build-content.mjs",
    "verify:manifest": "node scripts/verify-manifest.mjs",
    "preview": "vite preview",
    "test": "bash -O globstar -c 'node --test --experimental-strip-types --no-warnings src/**/__tests__/*.test.mjs'"
  },
  "dependencies": {
    "@clerk/clerk-js": "^6.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  }
}
