{
  "manifest_version": 3,
  "name": "AutoApply AI",
  "version": "1.0.0",
  "description": "Resume intelligence — semantic retrieval, ATS scoring, and smart form fill for every job application.",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*/*"
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "options_page": "src/options/index.html",
  "background": {
    "service_worker": "background/worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/detector.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    },
    {
      "matches": [
        "*://*.greenhouse.io/*",
        "*://*.lever.co/*",
        "*://*.myworkday.com/*",
        "*://*.workday.com/*",
        "*://*.ashbyhq.com/*",
        "*://*.smartrecruiters.com/*",
        "*://*.bamboohr.com/*",
        "*://*.icims.com/*",
        "*://*.jobvite.com/*",
        "*://*.taleo.net/*",
        "*://linkedin.com/jobs/*",
        "*://www.linkedin.com/jobs/*",
        "*://indeed.com/viewjob*",
        "*://www.indeed.com/viewjob*"
      ],
      "js": ["content/floatingPanel.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AutoApply AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
