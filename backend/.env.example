# AutoApply AI — Backend Environment Variables
# Copy to .env and fill in values before running locally.

# ── Core ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://autoapply:localdev@localhost:5432/autoapply
# Set to true when using Supabase or any managed Postgres (requires SSL)
DB_SSL_REQUIRE=false

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Encryption ────────────────────────────────────────────────────────────
# Required. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Invalid or missing values are caught at boot (FERNET_KEY validator).
FERNET_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
# Your Clerk instance URL, e.g. https://your-app.clerk.accounts.dev
CLERK_FRONTEND_API_URL=
CLERK_JWT_AUDIENCE=

# Dev-only: clerk_id resolved by get_current_user when ENVIRONMENT=development
# and no JWT / X-Clerk-User-Id header is sent. Must match an existing user's
# clerk_id. Leave blank in staging/production — config validation rejects a
# non-empty value when ENVIRONMENT=production.
DEV_TEST_USER_ID=

# JWT fallback (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# ── Ollama (local LLM) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── GitHub OAuth ──────────────────────────────────────────────────────────
# Create at https://github.com/settings/developers
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# ── GitHub Vault (optional, server-side fallback) ─────────────────────────
# Personal access token + repo coordinates used when no per-user GitHub
# account is connected. Leave blank to disable the server-side vault path.
GITHUB_TOKEN=
GITHUB_VAULT_OWNER=
GITHUB_VAULT_REPO=

# ── Monitoring (optional) ─────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────
# Your published Chrome extension ID (find after publishing to Web Store)
EXTENSION_ID=
