# AutoApply AI — Backend Environment Variables
# Copy to .env and fill in values before running locally.

# ── Core ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://autoapply:localdev@localhost:5432/autoapply

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
# Your Clerk instance URL, e.g. https://your-app.clerk.accounts.dev
CLERK_FRONTEND_API_URL=
CLERK_JWT_AUDIENCE=

# JWT fallback (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# ── Ollama (local LLM) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── GitHub OAuth ──────────────────────────────────────────────────────────
# Create at https://github.com/settings/developers
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# ── Monitoring (optional) ─────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────
# Your published Chrome extension ID (find after publishing to Web Store)
EXTENSION_ID=
